# ── Core ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
DEBUG=false                       # true → include exception details in 500 responses
SECRET_KEY=change-me-in-production

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=veritariffai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Or supply a full URL:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/veritariffai

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_ISSUER=https://veritariffai.co
JWT_AUDIENCE=veritariffai-api

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4                        # used by existing ai_agent service
OPENAI_CLASSIFICATION_MODEL=gpt-4o        # Import Analysis: HS classification
IMPORT_ANALYSIS_CONFIDENCE_THRESHOLD=0.75 # Review required below this score

# ── External Tariff APIs (optional — adapters have mock fallbacks) ────────────
HMRC_API_KEY=
TARIC_API_KEY=
HMRC_EORI_BASE_URL=https://api.service.hmrc.gov.uk/customs/eori

# ── Feature flags ─────────────────────────────────────────────────────────────
ACADEMIC_MOCK_ENABLED=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (empty = all for dev)
# CORS_ORIGINS=["https://veritariffai.co","https://app.veritariffai.co"]
